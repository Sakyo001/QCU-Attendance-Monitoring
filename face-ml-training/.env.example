# ============================================================
# Face Recognition API — Environment Configuration
# Copy this file to .env and adjust as needed
# ============================================================

# Database
DB_PATH=database/embeddings.db

# ArcFace mode: "insightface" (ONNX, default) or "pytorch" (custom trained)
ARCFACE_MODE=insightface

# Only needed when ARCFACE_MODE=pytorch:
# ARCFACE_MODEL_PATH=models/arcface/arcface_model.pth
# ARCFACE_BACKBONE=r100

# Anti-spoofing model directory
ANTISPOOF_MODEL_DIR=models/antispoof

# insightface detection model pack: buffalo_sc (fast) or buffalo_l (accurate)
DET_MODEL_NAME=buffalo_sc

# Inference device
DEVICE=cuda

# Recognition threshold (cosine similarity). Range: 0.0–1.0
# Higher = stricter matching.
SIM_THRESHOLD=0.6

# Anti-spoof threshold (P(real)). Range: 0.0–1.0
# Higher = reject more borderline cases.
REAL_THRESHOLD=0.7

# Server binding
HOST=0.0.0.0
PORT=8000
RELOAD=false

# CORS — set to your frontend origin in production, e.g. http://localhost:3000
ALLOWED_ORIGINS=*
