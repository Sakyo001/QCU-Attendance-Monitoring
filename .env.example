# =============================
# Frontend (Vercel) Environment
# =============================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (Vercel Functions / Route Handlers)
SUPABASE_SERVICE_ROLE_KEY=

# Face Recognition Backend (Railway)
# Use HTTPS base URL (no trailing slash). WebSockets will auto-convert to wss://
NEXT_PUBLIC_FACENET_API_URL=https://attendance-monitoring-api-production.up.railway.app

# Optional: local fallback used by the app when Railway is unreachable
# NEXT_PUBLIC_LOCAL_API_URL=http://localhost:8000

# Optional (only if you still use ArcFace endpoints somewhere)
# NEXT_PUBLIC_ARCFACE_API_URL=https://attendance-monitoring-api-production.up.railway.app
